# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# External recommendation services. Supported values: groq, openai.
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
GOOGLE_BOOKS_API_KEY=

# Newsletter sender account
NEWSLETTER_SENDER_EMAIL=
NEWSLETTER_SENDER_PASSWORD=
